# ------------------------------------------------------------------
# Copy this file to `.env` and adjust if needed. Defaults work for the
# Docker Compose setup out of the box.
# ------------------------------------------------------------------

# --- Build behind a TLS-inspecting proxy ---
# Set to 1 if `docker compose build` fails with SSL certificate errors
# (corporate firewall / antivirus that intercepts HTTPS). It relaxes
# certificate checks for pip and npm during the image builds only.
INSECURE_TLS=0

# --- Neo4j (graph database) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Inside Docker the backend reaches Neo4j at the service hostname `neo4j`.
NEO4J_URI=bolt://neo4j:7687

# --- Ollama (local LLM + embeddings) ---
# Inside Docker the backend reaches Ollama at the service hostname `ollama`.
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text
# Embedding dimension MUST match the embedding model (nomic-embed-text = 768).
EMBEDDING_DIM=768
# Context window for chat calls. Ollama's default is small and silently
# truncates long extraction prompts; raise it if you increase CHUNK_SIZE.
NUM_CTX=4096
# Near-greedy decoding for grounded answers (keeps them factual). Graph
# extraction always uses temperature 0.
ANSWER_TEMPERATURE=0.2

# --- RAG tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5
# Reranking: retrieve TOP_K * RERANK_OVERFETCH candidate chunks, then let the LLM
# reorder them by relevance and keep the best TOP_K. Set false to skip (faster).
ENABLE_RERANKING=true
RERANK_OVERFETCH=4
# Set to false to skip LLM entity/relationship extraction (faster ingest,
# falls back to plain vector RAG instead of GraphRAG).
ENABLE_ENTITY_EXTRACTION=true
# Safety cap on how many characters of each chunk are sent to the extractor
# (the graph is now built from every chunk, not just the document's opening).
MAX_EXTRACTION_CHARS=8000
OLLAMA_TIMEOUT=300
